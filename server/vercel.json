{
  "version": 2,
  "functions": {
    "api/index.js": {
      "includeFiles": "node_modules/swagger-ui-dist/**"
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/index.js"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/reminders",
      "schedule": "0 0 * * *"
    }
  ]
}
