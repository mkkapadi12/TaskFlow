# ─────────────────────────────────────────────────────────
#  TaskFlow – Server Environment Variables
#  Copy this file to .env and fill in your own values.
#  Never commit your real .env to version control.
# ─────────────────────────────────────────────────────────

# ── Server ───────────────────────────────────────────────
PORT=5000
NODE_ENV=development          # development | production
SERVER_URL=http://localhost:5000
ADDITIONAL_SERVER_URLS=http://localhost:5000

# ── Client origin (used in CORS + password-reset links) ──
CLIENT_URL=http://localhost:5173
ADDITIONAL_CLIENT_URLS = http://[IP_ADDRESS]:5173
IP_ADDRESS=your_wifi_ip_address


# ── MySQL Database ────────────────────────────────────────
# Full connection URL (used for reference / future ORMs)
DATABASE_URL=mysql://root:yourpassword@localhost:3306/your_db

DATABASE_NAME=your_db
DATABASE_HOST=localhost
DATABASE_USER=root
DATABASE_PASSWORD=yourpassword
DATABASE_PORT=3306

# ── JSON Web Token ────────────────────────────────────────
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d             # e.g. 1d | 7d | 30d

# ── Cloudinary (avatar uploads) ──────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── SMTP / Email (Nodemailer) ─────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password   # Gmail → App Passwords (not your login password)
MAIL_FROM="TaskFlow <your_email@gmail.com>"
